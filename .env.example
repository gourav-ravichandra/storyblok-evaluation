# Copy to .env.local (do not commit real tokens).

# Storyblok Preview token (Settings → Access Tokens in Storyblok — NOT the Management API token)
NEXT_PUBLIC_STORYBLOK_PREVIEW_TOKEN=

# published | draft
NEXT_PUBLIC_STORYBLOK_VERSION=published

# eu | us | ca | ap | cn
STORYBLOK_REGION=eu

# Used by the Storyblok bridge in production (fixes iframe postMessage origin)
NEXT_PUBLIC_SITE_URL=https://storyblok-evaluation.vercel.app
